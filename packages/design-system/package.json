{
  "name": "@fincheck/design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A design system for Fincheck app",
  "keywords": [
    "design-system",
    "tailwindcss",
    "react",
    "typescript"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles": "./dist/design-system.css",
    "./icons/expense": {
      "types": "./dist/icons/expense.d.ts",
      "import": "./dist/icons/expense.es.js",
      "require": "./dist/icons/expense.cjs.js"
    },
    "./icons/revenue": {
      "types": "./dist/icons/revenue.d.ts",
      "import": "./dist/icons/revenue.es.js",
      "require": "./dist/icons/revenue.cjs.js"
    },
    "./icons/account": {
      "types": "./dist/icons/account.d.ts",
      "import": "./dist/icons/account.es.js",
      "require": "./dist/icons/account.cjs.js"
    },
    "./icons/general": {
      "types": "./dist/icons/general.d.ts",
      "import": "./dist/icons/general.es.js",
      "require": "./dist/icons/general.cjs.js"
    },
    "./icons/colors": {
      "types": "./dist/icons/colors.d.ts",
      "import": "./dist/icons/colors.es.js",
      "require": "./dist/icons/colors.cjs.js"
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run tokens:watch\" \"vite build --watch\"",
    "dev:storybook": "vite --port 3001",
    "build": "npm run build:tokens && vite build",
    "build:tokens": "tsx scripts/build-tokens.ts",
    "tokens:watch": "nodemon --watch src/tokens --ext ts --ignore src/tokens/theme.css --exec \"npm run build:tokens\"",
    "build:lib": "vite build --mode library",
    "serve": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.545.0",
    "react-day-picker": "^9.13.0",
    "react-hook-form": "^7.66.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.14",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
