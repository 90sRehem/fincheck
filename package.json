{
  "name": "fincheck",
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "turbo": "^2.5.8",
    "typescript": "5.9.2",
    "vite-plugin-dts": "3.9.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.23",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "format": "biome format .",
    "check-types": "turbo run check-types",
    "server": "bunx json-server-auth server.json --routes routes.json -p 8000"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "json-server": "^0.17.0"
  }
}
